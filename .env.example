# tatu:ingore-file

# Required
TATU_SECRET_KEY=generate-with-openssl-rand-hex-32
TATU_ADMIN_EMAIL=admin@example.com

# Optional
TATU_DATABASE_URL=sqlite+aiosqlite:///./tatu.db
TATU_CORS_ORIGINS=["http://localhost:5173"]
TATU_HOST=0.0.0.0
TATU_PORT=8000
TATU_LOG_LEVEL=info

# SMTP (required for OTP login and invitations)
TATU_SMTP_HOST=localhost
TATU_SMTP_PORT=1025
TATU_SMTP_USER=
TATU_SMTP_PASSWORD=
TATU_SMTP_USE_TLS=false
TATU_SMTP_FROM=noreply@tatu.local

